{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": [
    "shellcheck@0.11.0",
    "shfmt@3.13.1",
    "editorconfig-checker@3.7.0",
    "pre-commit@4.5.1",
    "taplo@0.10.0",
    "yamllint@1.37.1",
    "stylua@2.5.2",
    "stow@2.4.1",
    "jq@1.8.1",
    "prettier@3.8.3",
    "bats@1.12.0",
    "zsh@5.9.1"
  ],
  "shell": {
    "init_hook": [
      "echo 'devbox: dotfiles toolchain ready — run `devbox run lint` or `devbox run fmt`' >&2"
    ],
    "scripts": {
      "lint": [
        "pre-commit run --all-files --color never"
      ],
      "fmt": [
        "bash scripts/fmt.sh"
      ],
      "test": [
        "bats tests/unit"
      ]
    }
  }
}
