# ┌┐ ┌─┐┌─┐┌─┐  ┌─┐┌─┐┌┬┐┬ ┬┌─┐
# ├┴┐├─┤└─┐├┤   ├─┘├─┤ │ ├─┤└─┐
# └─┘┴ ┴└─┘└─┘  ┴  ┴ ┴ ┴ ┴ ┴└─┘

export DOTFILES_HOME="$HOME/.dotfiles"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.local/cache"
export XDG_STATE_HOME="$HOME/.local/state"
export XDG_BIN_HOME="$HOME/.local/bin"
export XDG_PERSONAL_HOME="$HOME/.local/personal"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:=/tmp}"
export PATH="$XDG_BIN_HOME:$PATH"

# ┌─┐┌─┐┌┐┌┌─┐┬─┐┬┌─┐
# │ ┬├┤ │││├┤ ├┬┘││
# └─┘└─┘┘└┘└─┘┴└─┴└─┘

export OS=$(uname | tr '[:upper:]' '[:lower:]')
export LANG=en_AU.UTF-8
export CODE="$HOME/Code"
export EDITOR="nvim"
export THEME="Catamaran"

# ┌─┐┌─┐┌─┐┌┐┌┌┬┐┌─┐
# ├─┤│ ┬├┤ │││ │ └─┐
# ┴ ┴└─┘└─┘┘└┘ ┴ └─┘

if [[ "$OS" == "darwin" ]]; then
  export HOMEBREW_PREFIX="${HOMEBREW_PREFIX:-/opt/homebrew}"
  export GPG_SSH_PROGRAM=/Applications/1Password.app/Contents/MacOS/op-ssh-sign
  export SSH_AUTH_SOCK=~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock
  export GPG_PIN_ENTRY_PROGRAM="${HOMEBREW_PREFIX}/bin/pinentry-mac"
elif [[ "$OS" == "linux" ]]; then
  export GPG_SSH_PROGRAM=/opt/1Password/op-ssh-sign
  export SSH_AUTH_SOCK=~/.1password/agent.sock
  export GPG_PIN_ENTRY_PROGRAM=/usr/bin/pinentry-curses
fi

# ┌─┐┬┌┬┐┬ ┬┬ ┬┌┐
# │ ┬│ │ ├─┤│ │├┴┐
# └─┘┴ ┴ ┴ ┴└─┘└─┘

export GITHUB_ACCESS_TOKEN_REFERENCE="op://CLI/GitHub/ACCESS_TOKEN"
export GITHUB_REGISTRY_TOKEN_REFERENCE="op://CLI/GitHub/REGISTRY_TOKEN"

# ┌─┐┌─┐┌─┐┌┐┌┌─┐┬
# │ │├─┘├┤ │││├─┤│
# └─┘┴  └─┘┘└┘┴ ┴┴

export OPENAI_API_KEY_REFERENCE="op://CLI/OpenAI/API_KEY"

# ┌─┐┌─┐┌─┐┌─┐┬  ┌─┐
# │ ┬│ ││ ││ ┬│  ├┤
# └─┘└─┘└─┘└─┘┴─┘└─┘

export GOOGLEAI_API_KEY_REFERENCE="op://CLI/GoogleAI/API_KEY"

# ┌─┐┌┐┌┌┬┐┬ ┬┬─┐┌─┐┌─┐┬┌─┐
# ├─┤│││ │ ├─┤├┬┘│ │├─┘││
# ┴ ┴┘└┘ ┴ ┴ ┴┴└─└─┘┴  ┴└─┘

export ANTHROPIC_API_KEY_REFERENCE="op://CLI/Anthropic/API_KEY"

# ┌┐┌┌─┐┌┬┐┬┌─┐┌┐┌
# ││││ │ │ ││ ││││
# ┘└┘└─┘ ┴ ┴└─┘┘└┘

export NOTION_API_KEY_REFERENCE="op://CLI/Notion/API_KEY"
export NOTION_BOOKMARKS_ID_REFERENCE="op://CLI/Notion/BOOKMARKS_ID"

# ┌┐┌┌┐┌┌┐┌
# │││││││││
# ┘└┘┘└┘┘└┘

export NNN_PLUG="o:fzopen;f:fzcd;j:autojump;p:preview-tui;v:imgview"
export NNN_BMS="d:$DOTFILES_HOME"
export NNN_COLORS="4356"                      # Contexts: 1st, 2nd, 3rd, 4th
export NNN_FCOLORS="0e0b05040d060e0909030708" # BLK, CHR, DIR, EXE, REG, HARDLINK, SYMLINK, MISSING, ORPHAN, FIFO, SOCK, OTHER
export NNN_FIFO="/tmp/nnn.fifo"
export NNN_OPENER="nvim"

# ┌─┐┌─┐┬  ┌─┐┌┬┐┌┬┐┌─┐
# ├─┘├─┤│  ├┤  │  │ ├┤
# ┴  ┴ ┴┴─┘└─┘ ┴  ┴ └─┘

