# ┌┐ ┌─┐┌─┐┌─┐  ┌─┐┌─┐┌┬┐┬ ┬┌─┐
# ├┴┐├─┤└─┐├┤   ├─┘├─┤ │ ├─┤└─┐
# └─┘┴ ┴└─┘└─┘  ┴  ┴ ┴ ┴ ┴ ┴└─┘

export DOTFILES_HOME="$HOME/.dotfiles"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.local/cache"
export XDG_STATE_HOME="$HOME/.local/state"
export XDG_BIN_HOME="$HOME/.local/bin"
export XDG_PERSONAL_HOME="$HOME/.local/personal"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:=/tmp}"
export PATH="$XDG_BIN_HOME:$PATH"

# ┌─┐┌─┐┌┐┌┌─┐┬─┐┬┌─┐
# │ ┬├┤ │││├┤ ├┬┘││
# └─┘└─┘┘└┘└─┘┴└─┴└─┘

export OS=$(uname | tr '[:upper:]' '[:lower:]')
export LANG=en_AU.UTF-8
export CODE="$HOME/Code"
export EDITOR="nvim"
export THEME="Catamaran"
export PROMPT_ENGINE="ohmyposh" # ohmyposh | p10k | starship

# ┌─┐┌─┐┌─┐┌┐┌┌┬┐┌─┐
# ├─┤│ ┬├┤ │││ │ └─┐
# ┴ ┴└─┘└─┘┘└┘ ┴ └─┘

if [[ "$OS" == "darwin" ]]; then
  export HOMEBREW_PREFIX="${HOMEBREW_PREFIX:-/opt/homebrew}"
  export GPG_SSH_PROGRAM=/Applications/1Password.app/Contents/MacOS/op-ssh-sign
  export SSH_AUTH_SOCK=~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock
  export GPG_PIN_ENTRY_PROGRAM="${HOMEBREW_PREFIX}/bin/pinentry-mac"
elif [[ "$OS" == "linux" ]]; then
  export GPG_SSH_PROGRAM=/opt/1Password/op-ssh-sign
  export SSH_AUTH_SOCK=~/.1password/agent.sock
  export GPG_PIN_ENTRY_PROGRAM=/usr/bin/pinentry-curses
fi

# ┌─┐┬┌┬┐┬ ┬┬ ┬┌┐
# │ ┬│ │ ├─┤│ │├┴┐
# └─┘┴ ┴ ┴ ┴└─┘└─┘

export GITHUB_ACCESS_TOKEN_REFERENCE="op://CLI/GitHub/ACCESS_TOKEN"
export GITHUB_REGISTRY_TOKEN_REFERENCE="op://CLI/GitHub/REGISTRY_TOKEN"

# ┌─┐┌─┐┌─┐┌┐┌┌─┐┬
# │ │├─┘├┤ │││├─┤│
# └─┘┴  └─┘┘└┘┴ ┴┴

export OPENAI_API_KEY_REFERENCE="op://CLI/OpenAI/API_KEY"

# ┌─┐┌─┐┌─┐┌─┐┬  ┌─┐
# │ ┬│ ││ ││ ┬│  ├┤
# └─┘└─┘└─┘└─┘┴─┘└─┘

export GOOGLEAI_API_KEY_REFERENCE="op://CLI/GoogleAI/API_KEY"

# ┌─┐┌┐┌┌┬┐┬ ┬┬─┐┌─┐┌─┐┬┌─┐
# ├─┤│││ │ ├─┤├┬┘│ │├─┘││
# ┴ ┴┘└┘ ┴ ┴ ┴┴└─└─┘┴  ┴└─┘

export ANTHROPIC_API_KEY_REFERENCE="op://CLI/Anthropic/API_KEY"

# ┌┐┌┌─┐┌┬┐┬┌─┐┌┐┌
# ││││ │ │ ││ ││││
# ┘└┘└─┘ ┴ ┴└─┘┘└┘

export NOTION_API_KEY_REFERENCE="op://CLI/Notion/API_KEY"
export NOTION_BOOKMARKS_ID_REFERENCE="op://CLI/Notion/BOOKMARKS_ID"

# ┌┐┌┌┐┌┌┐┌
# │││││││││
# ┘└┘┘└┘┘└┘

export NNN_PLUG="o:fzopen;f:fzcd;j:autojump;p:preview-tui;v:imgview"
export NNN_BMS="d:$DOTFILES_HOME"
export NNN_COLORS="4356"                      # Contexts: 1st, 2nd, 3rd, 4th
export NNN_FCOLORS="0e0b05040d060e0909030708" # BLK, CHR, DIR, EXE, REG, HARDLINK, SYMLINK, MISSING, ORPHAN, FIFO, SOCK, OTHER
export NNN_FIFO="/tmp/nnn.fifo"
export NNN_OPENER="nvim"

# ┌─┐┌─┐┬  ┌─┐┌┬┐┌┬┐┌─┐
# ├─┘├─┤│  ├┤  │  │ ├┤
# ┴  ┴ ┴┴─┘└─┘ ┴  ┴ └─┘

# Named colors -- the palette; the only place hex literals live.
# Neutrals: BG0 (darkest) -> BG4 (lightest bg), NAVY is the blue-tinted
# background, FG0 (brightest) -> FG2 (dimmest), GRAY is the muted tone.
export PALETTE_BG0="#1d232b"
export PALETTE_BG1="#222831"
export PALETTE_BG2="#242a34"
export PALETTE_BG3="#323a44"
export PALETTE_BG4="#3a4555"
export PALETTE_NAVY="#202f42"
export PALETTE_FG0="#e1e4e8"
export PALETTE_FG1="#adbac7"
export PALETTE_FG2="#8296aa"
export PALETTE_GRAY="#515f72"

# Accents
export PALETTE_RED="#ff4b82"
export PALETTE_PINK="#ff75b5"
export PALETTE_ROSE="#fdaccb"
export PALETTE_ORANGE="#ff6b35"
export PALETTE_AMBER="#f5b168"
export PALETTE_YELLOW="#f4d35e"
export PALETTE_GREEN="#9ed47b"
export PALETTE_TEAL="#00b196"
export PALETTE_MINT="#00e8c6"
export PALETTE_CYAN="#04f6f6"
export PALETTE_SKY="#02d9fe"
export PALETTE_AZURE="#01bdfe"
export PALETTE_BLUE="#6fc1ff"
export PALETTE_STEEL="#599ac8"
export PALETTE_PURPLE="#a394cd"
export PALETTE_MAUVE="#766b95"

# Roles -- semantic aliases into the palette (must stay below the colors).

# Code: syntax colors (nvim highlights + bat theme)
export PALETTE_CODE_STRING="$PALETTE_MINT"
export PALETTE_CODE_KEYWORD="$PALETTE_AZURE"
export PALETTE_CODE_FUNCTION="$PALETTE_SKY"
export PALETTE_CODE_IDENTIFIER="$PALETTE_ROSE"
export PALETTE_CODE_CONSTANT="$PALETTE_ROSE"
export PALETTE_CODE_COMMENT="$PALETTE_GRAY"
export PALETTE_CODE_OPERATOR="$PALETTE_RED"
export PALETTE_CODE_PREPROCESSOR="$PALETTE_AMBER"
export PALETTE_CODE_SPECIAL="$PALETTE_PINK"

# UI: cross-tool chrome (fzf, sketchybar, borders, gh-dash, lazygit,
# process-compose, alfred, oh-my-posh, nvim)
export PALETTE_UI_ACCENT="$PALETTE_CYAN"
export PALETTE_UI_ACCENT_ALT="$PALETTE_PINK"
export PALETTE_UI_SUCCESS="$PALETTE_TEAL"
export PALETTE_UI_WARNING="$PALETTE_AMBER"
export PALETTE_UI_ERROR="$PALETTE_RED"
export PALETTE_UI_INFO="$PALETTE_BLUE"
export PALETTE_UI_HINT="$PALETTE_FG2"
export PALETTE_UI_FOCUS="$PALETTE_PURPLE"
export PALETTE_UI_BORDER="$PALETTE_SKY"
export PALETTE_UI_CURSOR="$PALETTE_ORANGE"

# Mode: vi-mode indicators (lualine + alacritty vi_mode_cursor)
export PALETTE_MODE_NORMAL="$PALETTE_SKY"
export PALETTE_MODE_INSERT="$PALETTE_YELLOW"
export PALETTE_MODE_VISUAL="$PALETTE_RED"
export PALETTE_MODE_REPLACE="$PALETTE_GREEN"
export PALETTE_MODE_COMMAND="$PALETTE_MAUVE"
