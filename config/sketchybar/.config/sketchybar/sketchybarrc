# в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•—    в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘  в•ҡв–Ҳв–Ҳв•”в•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—
# в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘
# в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ   в•ҡв•җв•қ    в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ  в•ҡв•җв•қ
# https://github.com/FelixKratz/SketchyBar
# https://felixkratz.github.io/SketchyBar/setup
# Note: defaults may be overridden via dotup-services

PLUGIN_DIR="$CONFIG_DIR/plugins"

source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/fonts.sh"

sketchybar --bar \
  position=top \
  height=36 \
  notch_offset=36 \
  sticky=on \
  color=$TRANSPARENT

default=(
  padding_left=2
  padding_right=2
  icon.font="$FONT_ICON"
  label.font="$FONT_LABEL"
  icon.color=$PALETTE_SE_PRIMARY
  label.color=$PALETTE_BA_PRIMARY_FG
  icon.padding_left=4
  icon.padding_right=2
  label.padding_left=4
  label.padding_right=4
)
sketchybar --default "${default[@]}"

separator=(
  icon="п…Ӯ"
  icon.color=$PALETTE_SE_ERROR
  background.padding_left=-2
  background.padding_right=-2
)

# в”¬  в”Ңв”Җв”җв”Ңв”Җв”җв”Ңв”¬в”җ
# в”Ӯ  в”ңв”Ө в”ңв”Ө  в”Ӯ
# в”ҙв”Җв”ҳв””в”Җв”ҳв””   в”ҙ

sketchybar --add event aerospace_workspace_change
sketchybar --add event aerospace_mode_change

host=(
  icon="п„ү"
  script="$PLUGIN_DIR/host.sh"
)

aerospace=(
  icon="пҶ—"
  label.padding_right=4
  label.font="$FONT_WORKSPACE"
  update_freq=5
  script="$PLUGIN_DIR/aerospace.sh"
)

window_count=(
  icon.drawing=off
  padding_left=0
  label.font="$FONT_WINDOW_COUNT"
  label.padding_left=2
  label.padding_right=8
  update_freq=5
  script="$PLUGIN_DIR/aerospace.sh"
)

front_app=(
  icon="у°ЈҶ"
  script="$PLUGIN_DIR/front-app.sh"
)

# Mode glyph; toggled instantly by aerospace.sh on aerospace_mode_change.
mode_indicator=(
  drawing=off
  label.font="$FONT_MODE"
  icon.padding_left=0
  icon.padding_right=0
  label.padding_left=0
  label.padding_right=0
  background.padding_left=-6
)

sketchybar \
  --add item host left --set host "${host[@]}" \
  --add item separator-host left --set separator-host "${separator[@]}" \
  --add item aerospace left --set aerospace "${aerospace[@]}" --subscribe aerospace aerospace_workspace_change aerospace_mode_change \
  --add item window_count left --set window_count "${window_count[@]}" \
  --add item mode_indicator left --set mode_indicator "${mode_indicator[@]}" \
  --add item front_app left --set front_app "${front_app[@]}" --subscribe front_app front_app_switched

# в”Ңв”Җв”җв”Ңв”Җв”җв”Ңв”җв”Ңв”Ңв”¬в”җв”Ңв”Җв”җв”¬в”Җв”җ
# в”Ӯ  в”ңв”Ө в”Ӯв”Ӯв”Ӯ в”Ӯ в”ңв”Ө в”ңв”¬в”ҳ
# в””в”Җв”ҳв””в”Җв”ҳв”ҳв””в”ҳ в”ҙ в””в”Җв”ҳв”ҙв””в”Җ

cpu=(
  icon="п’ј"
  update_freq=2
  script="$PLUGIN_DIR/cpu.sh"
)

memory=(
  icon="оҝ…"
  update_freq=15
  script="$PLUGIN_DIR/memory.sh"
)

disk=(
  icon="пғҮ"
  update_freq=60
  script="$PLUGIN_DIR/disk.sh"
)

network_down=(
  y_offset=-4
  background.padding_right=-67
  label.font="$FONT_NET_LABEL"
  icon.font="$FONT_NET_ICON"
  icon.highlight_color=$PALETTE_SE_ERROR
  icon="пҒЈ"
  update_freq=1
  script="$PLUGIN_DIR/network.sh"
)

network_up=(
  y_offset=5
  icon="пҒў"
  label.font="$FONT_NET_LABEL"
  icon.font="$FONT_NET_ICON"
  icon.highlight_color=$PALETTE_SE_ERROR
  update_freq=1
  script="$PLUGIN_DIR/network.sh"
)

sketchybar \
  --add item cpu center --set cpu "${cpu[@]}" \
  --add item memory center --set memory "${memory[@]}" \
  --add item disk center --set disk "${disk[@]}" \
  --add item separator-disk center --set separator-disk "${separator[@]}" \
  --add item network.down center --set network.down "${network_down[@]}" \
  --add item network.up center --set network.up "${network_up[@]}" \

# в”¬в”Җв”җв”¬в”Ңв”Җв”җв”¬ в”¬в”Ңв”¬в”җ
# в”ңв”¬в”ҳв”Ӯв”Ӯ в”¬в”ңв”Җв”Ө в”Ӯ
# в”ҙв””в”Җв”ҙв””в”Җв”ҳв”ҙ в”ҙ в”ҙ

clock=(
  icon="пҖ—"
  update_freq=1
  script="$PLUGIN_DIR/clock.sh"
)

date=(
  icon="у°ӯ§"
  update_freq=60
  script="$PLUGIN_DIR/date.sh"
)

weekday=(
  icon="уұЁұ"
  update_freq=3600
  script="$PLUGIN_DIR/weekday.sh"
)

week=(
  icon="уұЁҙ"
  update_freq=3600
  script="$PLUGIN_DIR/week.sh"
)

battery=(
  update_freq=120
  script="$PLUGIN_DIR/battery.sh"
)

volume=(
  script="$PLUGIN_DIR/volume.sh"
)

sketchybar \
  --add item clock right --set clock "${clock[@]}" \
  --add item separator-clock right --set separator-clock "${separator[@]}" \
  --add item date right --set date "${date[@]}" \
  --add item weekday right --set weekday "${weekday[@]}" \
  --add item week right --set week "${week[@]}" \
  --add item separator-week right --set separator-week "${separator[@]}" \
  --add item battery right --set battery "${battery[@]}" --subscribe battery system_woke power_source_change \
  --add item volume right --set volume "${volume[@]}" --subscribe volume volume_change

# Force all scripts to run the first time (never do this in a script)
sketchybar --update
