#!/bin/bash
# ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó      ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó
# ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ
# ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ
# ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ
# ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ
# ‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ
# Usage‚ĚĮ flash-keyboard <keyboard> <keymap> [--build]

set -euo pipefail

if [ "$#" -ne 2 ] && [ "$#" -ne 3 ]; then
  echo "‚ö† Usage‚ĚĮ $(basename "$0") <keyboard> <keymap> [--build]" >&2
  exit 1
fi

if [ -z "${DOTFILES_HOME:-}" ]; then
  echo "‚ö† DOTFILES_HOME is not set." >&2
  exit 1
fi

BRAND="${1%%/*}"

case $BRAND in
"keychron")
  FORK="keychron/qmk_firmware"
  BRANCH="master"
  COMMIT="b35bac6afbadc88cf6e8e3d1c8cc7494a510bb60" # pinned build commit (known-good)
  BUILD="${1//\//_}_$2.bin"
  ;;
"zsa")
  FORK="zsa/qmk_firmware"
  BRANCH="firmware25"
  COMMIT="f94ba44621d10b4d8549e5ad235f173963d3b89e" # pinned build commit (known-good)
  BUILD="${1//\//_}_$2.bin"
  ;;
*)
  FORK="qmk/qmk_firmware"
  BRANCH="master"
  COMMIT="fb48db4c8f59feb2ad64b41d53d708a0673b0df4" # pinned build commit (known-good)
  BUILD="${1//\//_}_$2.hex"
  ;;
esac

case "${3:-}" in
"") ;;
"--build")
  echo "‚Ć®ÔłŹ Building the firmware..."
  # Single-quoted so $1..$6 stay literal; values are passed as positional args
  # to sh (not interpolated), so a keyboard/keymap can't inject shell.
  # shellcheck disable=SC2016 # literal $1..$6 are intentional ‚ÄĒ the inner sh expands them
  build_script='
    set -e
    keyboard=$1 keymap=$2 branch=$3 fork=$4 commit=$5 build=$6
    git config --global http.sslVerify false
    qmk setup -H ./qmk_firmware -b "$branch" -y "$fork"
    git -C ./qmk_firmware checkout "$commit"
    git -C ./qmk_firmware submodule update --init --recursive
    cp -R /keyboards/* ./qmk_firmware/keyboards
    qmk compile -kb "$keyboard" -km "$keymap"
    mkdir -p /keyboards/.build
    cp "./qmk_firmware/$build" /keyboards/.build
  '
  docker run --rm -t \
    -w "/qmk" \
    -v "$DOTFILES_HOME/config/keyboards:/keyboards" \
    qmkfm/qmk_cli \
    sh -c "$build_script" flash-keyboard "$1" "$2" "$BRANCH" "$FORK" "$COMMIT" "$BUILD"
  ;;
*)
  echo "‚ö† Unknown option: $3. Did you mean --build?" >&2
  exit 1
  ;;
esac

FILE="$DOTFILES_HOME/config/keyboards/.build/$BUILD"
if [ ! -f "$FILE" ]; then
  echo "‚ö† There is no build. Use \`--build\` option to build and flash the firmware."
  exit 2
fi

echo "‚Ć®ÔłŹ Flashing..."

sleep 1 # let the device settle into bootloader mode

case $BRAND in
"keychron")
  dfu-util -a 0 -d 0483:DF11 -s 0x8000000:leave -D "$FILE"
  ;;
"zsa")
  dfu-util -a 0 -d 3297:0791 -s 0x08002000:leave -D "$FILE"
  ;;
*)
  dfu-programmer atmega32u4 erase --force
  dfu-programmer atmega32u4 flash "$FILE"
  dfu-programmer atmega32u4 reset
  ;;
esac

echo "‚Ć®ÔłŹ Done! $FORK fork on $BRANCH branch / keyboard:$1 / keymap:$2"
