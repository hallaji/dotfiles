#!/bin/bash

set -e

if ! command -v brew &>/dev/null; then
  exit 0
fi

cat <<EOF
┌┬┐┌─┐┌─┐
│││├─┤│
┴ ┴┴ ┴└─┘
EOF

# Installing Homebrew
# https://brew.sh

type brew &>/dev/null || curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh | bash

# Core packages
brew install \
  antigravity-cli \
  asdf \
  aws-cdk \
  awscli \
  bat \
  bison \
  claude-code \
  codex \
  copilot-cli \
  cowsay \
  ctags \
  ctop \
  ddgr \
  dfu-programmer \
  dfu-util \
  diff-so-fancy \
  direnv \
  docker \
  dry \
  eza \
  fd \
  ffmpeg \
  figlet \
  fortune \
  fswatch \
  fzf \
  gh \
  git \
  gnupg \
  go \
  gradle \
  htop \
  httpie \
  ifstat \
  imagemagick \
  jo \
  jpeg-xl \
  jq \
  jump \
  kafka \
  killport \
  kotlin \
  kotlin-language-server \
  ktlint \
  lazygit \
  lolcat \
  mermaid-cli \
  neovim \
  nmap \
  node \
  pgcli \
  pinentry \
  pinentry-mac \
  pi-coding-agent \
  poetry \
  python \
  re2c \
  ripgrep \
  ruby \
  shortcat \
  showkey \
  solargraph \
  sqlc \
  starship \
  stow \
  the_silver_searcher \
  tig \
  tldr \
  tmux \
  tmuxinator \
  tree \
  tree-sitter \
  tree-sitter-cli \
  typescript \
  unbound \
  urlview \
  vim \
  virtualenv \
  wallpaper \
  watch \
  wget \
  zoxide \
  zsh

# Third-party packages
brew install \
  common-fate/granted/granted \
  f1bonacc1/tap/process-compose \
  felixkratz/formulae/borders \
  felixkratz/formulae/sketchybar \
  jandedobbeleer/oh-my-posh/oh-my-posh \
  koekeishiya/formulae/skhd \
  supabase/tap/supabase

# Core casks
brew install --cask \
  1password-cli \
  alacritty \
  alfred \
  chromedriver \
  font-fira-code \
  font-fira-code-nerd-font \
  font-hack-nerd-font \
  font-jetbrains-mono \
  font-jetbrains-mono-nerd-font \
  font-roboto \
  font-roboto-mono \
  font-roboto-mono-nerd-font \
  fork \
  ghostty \
  gifox \
  gitbutler \
  github \
  gcloud-cli \
  itsycal \
  jetbrains-toolbox \
  monodraw \
  orbstack \
  postico \
  postman \
  qmk-toolbox \
  session-manager-plugin \
  visual-studio-code

# Third-party casks
brew install --cask \
  nikitabobko/tap/aerospace

# Installing Nix and Devbox
# https://docs.determinate.systems
# https://www.jetify.com/docs/devbox/installing_devbox

if [[ "$DOTFILES_PROFILE" != "CLTRMP" ]]; then
  if command -v nix &>/dev/null; then
    echo "Already installed: $(nix --version)"
  else
    # https://github.com/DeterminateSystems/nix-installer
    echo "Nix not found, installing..."
    curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix |
      sh -s -- install --no-confirm --extra-conf "trusted-users = root @admin"
  fi
  type devbox &>/dev/null || curl -fsSL https://get.jetify.com/devbox | FORCE=1 bash
else
  # https://github.com/cultureamp/hotel — owns nix/devbox on the work machine
  ruby -e "$(curl -fsSL https://raw.githubusercontent.com/cultureamp/devbox-extras/main/scripts/github_auth.rb)"
  hotel setup ensure
fi

# Profile-specific installations

if [[ "$DOTFILES_PROFILE" == "CLTRMP" ]]; then
  brew tap cultureamp/tap

  # https://github.com/cultureamp/silk
  brew install silk-cli

  # https://github.com/cultureamp/wilma
  brew install wilma
fi
