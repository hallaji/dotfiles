#!/bin/bash

set -e

cat <<EOF
┌─┐┌─┐┬─┐┌─┐┌─┐┌┐┌┌─┐┬
├─┘├┤ ├┬┘└─┐│ ││││├─┤│
┴  └─┘┴└─└─┘└─┘┘└┘┴ ┴┴─┘
EOF

[ -f ~/.env ] && source ~/.env
XDG_PERSONAL_HOME="${XDG_PERSONAL_HOME:-${HOME}/.local/personal}"
PERSONAL_ENV_FILE="${XDG_PERSONAL_HOME}/env"

mkdir -p "$XDG_PERSONAL_HOME"
chmod 700 "$XDG_PERSONAL_HOME"

BOLD_CYAN='\033[1;36m'
RED='\033[0;31m'
RESET='\033[0m'

DOTFILES_HOME="${DOTFILES_HOME:-$HOME/.dotfiles}"
PERSONAL_SPEC="$DOTFILES_HOME/config/env/.env.personal.spec"

if [ ! -f "$PERSONAL_SPEC" ]; then
  printf "${RED}Personal var spec not found: %s${RESET}\n" "$PERSONAL_SPEC" >&2
  exit 1
fi

# Personal var list — single source of truth shared with the doctor's `personal`
# check (tools/doctor/personal.go). One entry per line: NAME or NAME:secret.
VARS=()
while IFS= read -r line; do
  line="${line%%#*}"           # strip comments
  line="${line//[[:space:]]/}" # drop whitespace
  [ -z "$line" ] && continue
  VARS+=("$line")
done <"$PERSONAL_SPEC"

# Read a secret value echoing * per character, supports backspace and paste
read_secret() {
  local prompt="$1" _outvar="$2" _value="" char="" old_stty
  printf '%s' "$prompt"
  old_stty="$(stty -g </dev/tty 2>/dev/null)"
  stty -echo </dev/tty 2>/dev/null
  trap 'stty "$old_stty" </dev/tty 2>/dev/null' INT TERM EXIT
  while IFS= read -r -s -n1 char </dev/tty; do
    if [[ -z "$char" ]]; then
      break
    elif [[ "$char" == $'\177' || "$char" == $'\010' ]]; then
      if [[ -n "$_value" ]]; then
        _value="${_value%?}"
        printf '\b \b'
      fi
    else
      _value+="$char"
      printf '*'
    fi
  done
  stty "$old_stty" </dev/tty 2>/dev/null
  trap - INT TERM EXIT
  echo
  printf -v "$_outvar" '%s' "$_value"
}

# Read a saved value directly from the file (not the live environment).
# Warns if the stored value spans multiple lines (not supported) and returns
# only the first line so the rest of the script can continue safely.
saved_value() {
  local line
  line=$(grep -m1 "^export ${1}=" "$PERSONAL_ENV_FILE" 2>/dev/null) || return 0
  if ! printf '%s' "$line" | grep -q '"[^"]*"'; then
    printf "${RED}Warning: %s contains a multi-line value — only the first line will be kept. Re-enter to fix.${RESET}\n" "$1" >&2
  fi
  printf '%s' "$line" | cut -d'"' -f2
}

# Check if a key exists in the file regardless of value
key_exists() {
  grep -q "^export ${1}=" "$PERSONAL_ENV_FILE" 2>/dev/null
}

# Load existing saved values as defaults so unchanged ones are preserved
if [ -f "$PERSONAL_ENV_FILE" ]; then
  for entry in "${VARS[@]}"; do
    var="${entry%%:*}"
    printf -v "$var" '%s' "$(saved_value "$var")"
  done
fi

if command -v fzf &>/dev/null; then
  entries=""
  for entry in "${VARS[@]}"; do
    var="${entry%%:*}"
    if [[ -n "$(saved_value "$var")" ]]; then
      entries+="$(printf '%b%s %b' "$BOLD_CYAN" "$var" "$RESET")\n"
    elif key_exists "$var"; then
      entries+="$(printf '%s ' "$var")\n"
    else
      entries+="$(printf '%b%s %b' "$RED" "$var" "$RESET")\n"
    fi
  done

  selected_vars=()
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    selected_vars+=("$(awk '{print $1}' <<<"$line")")
  done < <(printf "%b" "$entries" |
    fzf --multi --ansi \
      --prompt="Select to update (Tab/Space=select, Enter=confirm): " \
      --bind 'space:toggle') || true

  for var in "${selected_vars[@]}"; do
    entry=""
    for e in "${VARS[@]}"; do
      [[ "${e%%:*}" == "$var" ]] && entry="$e" && break
    done
    if [[ "$entry" == *:secret ]]; then
      read_secret "${var}: " value
    else
      read -r -p "${var}: " value </dev/tty
    fi
    printf -v "$var" '%s' "$value"
  done
else
  ask() {
    local var="$1"
    local secret="${2:-false}"
    read -r -p "Update ${var}? [y/N] " answer </dev/tty
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      if [[ "$secret" == "true" ]]; then
        read_secret "${var}: " value
      else
        read -r -p "${var}: " value </dev/tty
      fi
      printf -v "$var" '%s' "$value"
    fi
  }

  for entry in "${VARS[@]}"; do
    var="${entry%%:*}"
    if [[ "$entry" == *:secret ]]; then
      ask "$var" true
    else
      ask "$var"
    fi
  done
fi

save_failed() {
  printf "${RED}Failed to save personal settings to %s${RESET}\n" "$PERSONAL_ENV_FILE" >&2
  exit 1
}

tmp="$(mktemp "${PERSONAL_ENV_FILE}.XXXXXX")" || save_failed
trap 'rm -f "$tmp"' EXIT

{
  for entry in "${VARS[@]}"; do
    var="${entry%%:*}"
    printf 'export %s="%s"\n' "$var" "${!var}"
  done
} >"$tmp" || save_failed

chmod 600 "$tmp" || save_failed
mv "$tmp" "$PERSONAL_ENV_FILE" || save_failed

echo "Personal settings saved. Run 'dotup doctor' to verify them."
