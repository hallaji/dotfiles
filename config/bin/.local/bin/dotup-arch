#!/bin/bash

set -e

if ! grep -q "Arch Linux" /etc/os-release &>/dev/null; then
  exit 0
fi

cat <<EOF
в”Ңв”Җв”җв”¬в”Җв”җв”Ңв”Җв”җв”¬ в”¬
в”ңв”Җв”Өв”ңв”¬в”ҳв”Ӯ  в”ңв”Җв”Ө
в”ҙ в”ҙв”ҙв””в”Җв””в”Җв”ҳв”ҙ в”ҙ
EOF

# Pacman packages
# https://wiki.archlinux.org/title/Pacman

sudo pacman -Syu

# Installing Nix
# https://nix.dev/install-nix#install-nix

type nix &>/dev/null || curl -L https://nixos.org/nix/install | sh -s -- --daemon

# Installing Devbox
# https://www.jetify.com/docs/devbox/installing_devbox

type devbox &>/dev/null || curl -fsSL https://get.jetify.com/devbox | bash

sudo pacman -S --needed \
  alacritty \
  base-devel \
  cowsay \
  curl \
  diff-so-fancy \
  direnv \
  dmenu \
  dolphin \
  figlet \
  firefox \
  fzf \
  ghostty \
  git \
  github-cli \
  go \
  hyprland \
  imagemagick \
  inetutils \
  i3 \
  jq \
  lazygit \
  less \
  libfido2 \
  lolcat \
  mermaid-cli \
  neovim \
  openssh \
  pam-u2f \
  pi-coding-agent \
  stow \
  tk \
  tmux \
  tree-sitter-cli \
  ttf-jetbrains-mono-nerd \
  vim \
  wget \
  wofi \
  xclip \
  yubikey-manager \
  zoxide \
  zsh

# Building AUR packages
# https://aur.archlinux.org

# https://github.com/Jguer/yay
sudo rm -rf /tmp/yay &&
  git clone https://aur.archlinux.org/yay.git /tmp/yay &&
  cd /tmp/yay &&
  makepkg -si --noconfirm

# https://asdf-vm.com/guide/getting-started.html#_1-install-asdf
yay -S asdf-vm

# https://ohmyposh.dev/docs/installation/linux
yay -S oh-my-posh-bin

# https://snapcraft.io/docs/tutorials/install-the-daemon/arch-linux/
sudo rm -rf /tmp/snapd &&
  git clone https://aur.archlinux.org/snapd.git /tmp/snapd &&
  cd /tmp/snapd &&
  makepkg -si --noconfirm
sudo systemctl enable --now snapd.socket
sudo systemctl enable --now snapd.apparmor.service
[ -e /snap ] || sudo ln -s /var/lib/snapd/snap /snap

# Snap on Arch Linux
# https://snapcraft.io/docs/installing-snap-on-arch-linux

sudo snap install hey-mail
sudo snap install spotify
sudo snap install code --classic
sudo snap refresh

# 1Pssword CLI
# https://developer.1password.com/docs/cli/get-started/#step-1-install-1password-cli
wget "https://cache.agilebits.com/dist/1P/op2/pkg/v2.33.1/op_linux_amd64_v2.33.1.zip" -O op.zip &&
  unzip -d op op.zip &&
  sudo mv op/op /usr/local/bin/ &&
  rm -r op.zip op &&
  sudo groupadd -f onepassword-cli &&
  sudo chgrp onepassword-cli /usr/local/bin/op &&
  sudo chmod g+s /usr/local/bin/op
